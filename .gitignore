# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Zuzi Studio — runtime state
/data
/backups
/tmp

# Generated by scripts/stamp-sw.ts on every dev start + build. Source of
# truth is scripts/sw-template.js. The committed copy would otherwise drift
# from the template on every checkout that runs predev/build.
/public/sw.js

# Zuzi's source sketches — her IP, never commit
/samples/inputs/

# IDE
.vscode/
.idea/

# macOS
.DS_Store
